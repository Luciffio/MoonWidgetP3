<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D0D1A"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="MOON WIDGET"
        android:textColor="#FFD700"
        android:textSize="20sp"
        android:fontFamily="monospace"
        android:letterSpacing="0.2"
        android:layout_marginBottom="32dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="BACKGROUND"
        android:textColor="#888899"
        android:textSize="11sp"
        android:fontFamily="monospace"
        android:letterSpacing="0.15"
        android:layout_marginBottom="12dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="32dp">

        <View android:id="@+id/color_dark_blue"
            android:layout_width="44dp" android:layout_height="44dp"
            android:background="#0D0D1A" android:layout_marginEnd="12dp"/>
        <View android:id="@+id/color_black"
            android:layout_width="44dp" android:layout_height="44dp"
            android:background="#000000" android:layout_marginEnd="12dp"/>
        <View android:id="@+id/color_dark_purple"
            android:layout_width="44dp" android:layout_height="44dp"
            android:background="#1A0D2E" android:layout_marginEnd="12dp"/>
        <View android:id="@+id/color_dark_green"
            android:layout_width="44dp" android:layout_height="44dp"
            android:background="#0D1A0D" android:layout_marginEnd="12dp"/>
        <View android:id="@+id/color_dark_red"
            android:layout_width="44dp" android:layout_height="44dp"
            android:background="#1A0D0D"/>
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SHOW / HIDE"
        android:textColor="#888899"
        android:textSize="11sp"
        android:fontFamily="monospace"
        android:letterSpacing="0.15"
        android:layout_marginBottom="16dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Дата след. полнолуния"
            android:textColor="#CCCCDD"
            android:fontFamily="monospace"
            android:textSize="13sp"/>
        <Switch
            android:id="@+id/switch_full_moon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Название фазы"
            android:textColor="#CCCCDD"
            android:fontFamily="monospace"
            android:textSize="13sp"/>
        <Switch
            android:id="@+id/switch_phase_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="40dp">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Иллюминация %"
            android:textColor="#CCCCDD"
            android:fontFamily="monospace"
            android:textSize="13sp"/>
        <Switch
            android:id="@+id/switch_illumination"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true"/>
    </LinearLayout>

    <Button
        android:id="@+id/btn_save"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="СОХРАНИТЬ"
        android:fontFamily="monospace"
        android:letterSpacing="0.15"
        android:backgroundTint="#FFD700"
        android:textColor="#0D0D1A"/>

</LinearLayout>