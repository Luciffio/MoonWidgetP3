<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#080810"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MOON WIDGET"
            android:textColor="#FFD700"
            android:textSize="22sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.2"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tv_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="НАСТРОЙКИ"
            android:textColor="#444466"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.15"
            android:layout_marginBottom="20dp"/>

        <!-- ЯЗЫК -->
        <TextView
            android:id="@+id/tv_lang_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ЯЗЫК / LANGUAGE / 言語"
            android:textColor="#888899"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.1"
            android:layout_marginBottom="10dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="28dp">

            <Button
                android:id="@+id/btn_lang_en"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:text="EN"
                android:textSize="13sp"
                android:fontFamily="monospace"
                android:layout_marginEnd="8dp"
                android:backgroundTint="#FFD700"
                android:textColor="#0D0D1A"/>

            <Button
                android:id="@+id/btn_lang_ru"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:text="RU"
                android:textSize="13sp"
                android:fontFamily="monospace"
                android:layout_marginEnd="8dp"
                android:backgroundTint="#222233"
                android:textColor="#888899"/>

            <Button
                android:id="@+id/btn_lang_jp"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:text="JP"
                android:textSize="13sp"
                android:fontFamily="monospace"
                android:backgroundTint="#222233"
                android:textColor="#888899"/>

        </LinearLayout>

        <!-- ПРЕВЬЮ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="36dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginEnd="8dp">

                <TextView
                    android:id="@+id/tv_preview_now"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="СЕЙЧАС"
                    android:textColor="#444466"
                    android:textSize="8sp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.15"
                    android:layout_marginBottom="6dp"/>

                <RelativeLayout
                    android:id="@+id/preview_card"
                    android:layout_width="match_parent"
                    android:layout_height="140dp"
                    android:background="@drawable/preview_bg"
                    android:padding="10dp">

                    <TextView
                        android:id="@+id/preview_full_moon"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentTop="true"
                        android:layout_alignParentStart="true"
                        android:textColor="#888899"
                        android:textSize="8sp"
                        android:fontFamily="monospace"
                        android:text="🌕 1 APR"/>

                    <ImageView
                        android:id="@+id/preview_moon"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:layout_centerInParent="true"/>

                    <TextView
                        android:id="@+id/preview_phase_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentBottom="true"
                        android:layout_alignParentStart="true"
                        android:textColor="#888899"
                        android:textSize="7sp"
                        android:fontFamily="monospace"
                        android:text="FULL MOON"/>

                    <TextView
                        android:id="@+id/preview_illumination"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentBottom="true"
                        android:layout_alignParentEnd="true"
                        android:textColor="#FFD700"
                        android:textSize="13sp"
                        android:fontFamily="monospace"
                        android:text="95%"/>
                </RelativeLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/tv_preview_full"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ПОЛНОЛУНИЕ"
                    android:textColor="#444466"
                    android:textSize="8sp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.15"
                    android:layout_marginBottom="6dp"/>

                <RelativeLayout
                    android:id="@+id/preview_card_full"
                    android:layout_width="match_parent"
                    android:layout_height="140dp"
                    android:background="@drawable/preview_bg"
                    android:padding="10dp">

                    <TextView
                        android:id="@+id/preview_full_moon2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentTop="true"
                        android:layout_alignParentStart="true"
                        android:textColor="#888899"
                        android:textSize="8sp"
                        android:fontFamily="monospace"
                        android:text="🌕 13 APR"/>

                    <ImageView
                        android:id="@+id/preview_moon_full"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:layout_centerInParent="true"/>

                    <TextView
                        android:id="@+id/preview_phase_name2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentBottom="true"
                        android:layout_alignParentStart="true"
                        android:textColor="#888899"
                        android:textSize="7sp"
                        android:fontFamily="monospace"
                        android:text="FULL MOON"/>

                    <TextView
                        android:id="@+id/preview_illumination2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentBottom="true"
                        android:layout_alignParentEnd="true"
                        android:textColor="#FFD700"
                        android:textSize="13sp"
                        android:fontFamily="monospace"
                        android:text="100%"/>
                </RelativeLayout>
            </LinearLayout>

        </LinearLayout>

        <!-- ЦВЕТ ФОНА -->
        <TextView
            android:id="@+id/tv_color_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ЦВЕТ ФОНА"
            android:textColor="#888899"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.15"
            android:layout_marginBottom="14dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <View
                android:id="@+id/color_preview_swatch"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginEnd="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="#"
                android:textColor="#888899"
                android:textSize="16sp"
                android:fontFamily="monospace"
                android:layout_marginEnd="4dp"/>

            <EditText
                android:id="@+id/et_hex"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="0D0D1A"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:fontFamily="monospace"
                android:background="@android:color/transparent"
                android:inputType="textNoSuggestions"
                android:maxLength="6"
                android:maxLines="1"
                android:imeOptions="actionDone"
                android:hint="RRGGBB"
                android:textColorHint="#333355"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">
            <TextView android:layout_width="20dp" android:layout_height="wrap_content"
                android:text="R" android:textColor="#FF4444" android:textSize="12sp"
                android:fontFamily="monospace" android:layout_marginEnd="10dp"/>
            <SeekBar android:id="@+id/seek_r" android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:max="255" android:progressTint="#FF4444" android:thumbTint="#FF4444"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">
            <TextView android:layout_width="20dp" android:layout_height="wrap_content"
                android:text="G" android:textColor="#44FF88" android:textSize="12sp"
                android:fontFamily="monospace" android:layout_marginEnd="10dp"/>
            <SeekBar android:id="@+id/seek_g" android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:max="255" android:progressTint="#44FF88" android:thumbTint="#44FF88"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">
            <TextView android:layout_width="20dp" android:layout_height="wrap_content"
                android:text="B" android:textColor="#4488FF" android:textSize="12sp"
                android:fontFamily="monospace" android:layout_marginEnd="10dp"/>
            <SeekBar android:id="@+id/seek_b" android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:max="255" android:progressTint="#4488FF" android:thumbTint="#4488FF"/>
        </LinearLayout>

        <!-- ПРЕСЕТЫ -->
        <TextView
            android:id="@+id/tv_presets_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ПРЕСЕТЫ"
            android:textColor="#888899"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.15"
            android:layout_marginBottom="12dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="32dp">

            <LinearLayout android:id="@+id/preset_1"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:gravity="center" android:layout_marginEnd="8dp">
                <View android:layout_width="36dp" android:layout_height="36dp" android:background="#303030"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="GRAPHITE" android:textColor="#666677" android:textSize="7sp"
                    android:fontFamily="monospace" android:layout_marginTop="5dp"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/preset_2"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:gravity="center" android:layout_marginEnd="8dp">
                <View android:layout_width="36dp" android:layout_height="36dp" android:background="#0D0D1A"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="MIDNIGHT" android:textColor="#666677" android:textSize="7sp"
                    android:fontFamily="monospace" android:layout_marginTop="5dp"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/preset_3"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:gravity="center" android:layout_marginEnd="8dp">
                <View android:layout_width="36dp" android:layout_height="36dp" android:background="#1A0D2E"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="PERSONA" android:textColor="#666677" android:textSize="7sp"
                    android:fontFamily="monospace" android:layout_marginTop="5dp"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/preset_4"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:gravity="center" android:layout_marginEnd="8dp">
                <View android:layout_width="36dp" android:layout_height="36dp" android:background="#0A1628"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="ABYSS" android:textColor="#666677" android:textSize="7sp"
                    android:fontFamily="monospace" android:layout_marginTop="5dp"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/preset_5"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:gravity="center">
                <View android:layout_width="36dp" android:layout_height="36dp" android:background="#000000"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="VOID" android:textColor="#666677" android:textSize="7sp"
                    android:fontFamily="monospace" android:layout_marginTop="5dp"/>
            </LinearLayout>

        </LinearLayout>

        <!-- DARK HOUR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#0D1A0D"
            android:padding="14dp"
            android:layout_marginBottom="28dp">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌑 DARK HOUR"
                    android:textColor="#00FF88"
                    android:textSize="13sp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.15"/>
                <TextView
                    android:id="@+id/tv_dark_hour_desc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="зелёное свечение при полнолунии"
                    android:textColor="#336644"
                    android:textSize="10sp"
                    android:fontFamily="monospace"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>
            <Switch
                android:id="@+id/switch_dark_hour"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- ЭЛЕМЕНТЫ -->
        <TextView
            android:id="@+id/tv_elements_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ЭЛЕМЕНТЫ"
            android:textColor="#888899"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.15"
            android:layout_marginBottom="16dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">
            <TextView
                android:id="@+id/tv_sw_full_moon"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Дата след. полнолуния"
                android:textColor="#CCCCDD"
                android:fontFamily="monospace"
                android:textSize="13sp"/>
            <Switch android:id="@+id/switch_full_moon"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:checked="true"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">
            <TextView
                android:id="@+id/tv_sw_phase"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Название фазы"
                android:textColor="#CCCCDD"
                android:fontFamily="monospace"
                android:textSize="13sp"/>
            <Switch android:id="@+id/switch_phase_name"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:checked="true"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="36dp">
            <TextView
                android:id="@+id/tv_sw_illum"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Иллюминация %"
                android:textColor="#CCCCDD"
                android:fontFamily="monospace"
                android:textSize="13sp"/>
            <Switch android:id="@+id/switch_illumination"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:checked="true"/>
        </LinearLayout>

        <Button
            android:id="@+id/btn_save"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="ПРИМЕНИТЬ К ВИДЖЕТУ"
            android:fontFamily="monospace"
            android:letterSpacing="0.1"
            android:backgroundTint="#FFD700"
            android:textColor="#0D0D1A"/>

    </LinearLayout>
</ScrollView>